---
import Layout from '../layouts/Layout.astro';
import App from '../components/App';
---

<Layout title="A Trotar - Mejores momentos para trotar">
  <section class="py-8">
    <p class="text-brutalist-text/80 text-lg mb-4 max-w-xl mx-auto opacity-80">
      Descubre cuándo las condiciones climáticas y la calidad del aire son ideales para tu entrenamiento al aire libre.
    </p>
    <p class="text-brutalist-yellow text-sm mb-8 max-w-xl mx-auto">
      Dale click a "USAR MI UBICACIÓN" y aceptá el permiso para saber automáticamente el mejor momento para trotar en tu zona.
    </p>
    
    <App client:load />
  </section>

  <footer class="mt-16 pt-4">
    <div class="brutal-box p-4 mb-8">
      <p class="text-center font-bold text-sm uppercase tracking-wide">
        ADVERTENCIA: DATOS DE POLEN Y AQI PUEDEN NO ESTAR DISPONIBLES EN ARGENTINA Y OTRAS REGIONES LATAM
      </p>
    </div>
    <p class="text-center text-brutalist-text/60 text-sm">
      Creado por Martín Alfredo Dumont — Todos los derechos reservados.
    </p>
  </footer>
</Layout>